# title
VITE_GLOB_APP_TITLE = 'AI卫士'

# port
VITE_PORT = 8066

# open 运行 npm run dev 时自动打开浏览器
VITE_OPEN = true

# 是否生成包预览文件
VITE_REPORT = false

# 是否开启gzip压缩
VITE_BUILD_GZIP = false

# 是否删除生产环境 console
VITE_DROP_CONSOLE = true

# 热更新
VITE_HRM = true

# 接口请求路径
VITE_BASE_URL = "/react/"

# 接口请求路径
VITE_API_URL = ""

VITE_MSG_URL = ""
